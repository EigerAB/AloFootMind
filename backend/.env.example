# PostgreSQL
DB_URL=postgresql+asyncpg://alofootmind:alofootmind@localhost:5432/alofootmind

# Redis
REDIS_URL=redis://localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# LLM APIs
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=your_openai_api_key_here

# StatsBomb data directory (absolute path to open-data repo)
STATSBOMB_DATA_PATH=/path/to/statsbomb/open-data/data

# Embedding model (local path or HuggingFace model ID)
EMBEDDING_MODEL=BAAI/bge-m3

# App settings
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# Auth / JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production

# Email (163 SMTP)
# Get authorization code at: https://mail.163.com → Settings → Client authorization password
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_163_address@163.com
SMTP_PASSWORD=your_163_auth_code
MAIL_FROM=your_163_address@163.com
