# PostgreSQL
DB_URL=postgresql+asyncpg://alofootmind:alofootmind@localhost:5432/alofootmind

# Redis
REDIS_URL=redis://localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# LLM APIs
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# StatsBomb data directory (absolute path to open-data repo)
STATSBOMB_DATA_PATH=/path/to/statsbomb/open-data/data

# Embedding model (local path or HuggingFace model ID)
EMBEDDING_MODEL=BAAI/bge-m3

# App settings
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
